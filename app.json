{
  "expo": {
    "name": "WalletWarp",
    "slug": "flo-finance",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "automatic",
    "icon": "./assets/icon.png",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "cover",
      "backgroundColor": "#FFFFFF"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.walletwarp.app",
      "infoPlist": {
        "NSFaceIDUsageDescription": "Use Face ID to unlock WalletWarp"
      }
    },
    "android": {
      "package": "com.walletwarp.app",
      "versionCode": 1,
      "permissions": [
        "USE_BIOMETRIC",
        "USE_FINGERPRINT",
        "CAMERA"
      ],
      "softwareKeyboardLayoutMode": "pan",
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#0D0D14"
      }
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-font",
      "expo-notifications",
      "expo-secure-store",
      "expo-local-authentication",
      [
        "expo-image-picker",
        {
          "photosPermission": "Allow WalletWarp to access your photos to set a profile picture and attach receipts.",
          "cameraPermission": "Allow WalletWarp to use your camera to take profile photos and receipt images."
        }
      ],
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#FFFFFF",
          "image": "./assets/splash.png",
          "resizeMode": "cover",
          "android": {
            "backgroundColor": "#FFFFFF",
            "image": "./assets/splash.png",
            "resizeMode": "cover"
          },
          "ios": {
            "backgroundColor": "#FFFFFF",
            "image": "./assets/splash.png",
            "resizeMode": "cover"
          }
        }
      ]
    ],
    "extra": {
      "eas": {
        "projectId": "c10fbeef-8925-4f81-85aa-8237db2c1ee6"
      }
    },
    "cli": {
      "appVersionSource": "local"
    }
  }
}
